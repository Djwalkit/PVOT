# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# App type: Web application
# Authorized redirect URIs: http://localhost:3000/callback (dev)
#                           https://yourdomain.com/callback (prod)

NEXT_PUBLIC_GOOGLE_CLIENT_ID=add
GOOGLE_CLIENT_SECRET=add
# ── App URL ───────────────────────────────────────────────────────────────────
# Used to construct the OAuth redirect URI.
# Development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (uncomment and set):
# NEXT_PUBLIC_APP_URL=https://pvot.yourdomain.com

# ── Build ID (for query cache busting) ───────────────────────────────────────
# Automatically set by CI/CD. Leave empty for local dev.
# NEXT_PUBLIC_BUILD_ID=